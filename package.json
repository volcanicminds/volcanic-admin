{
  "name": "@volcanicminds/admin",
  "version": "0.0.1",
  "codename": "phoenix",
  "license": "MIT",
  "description": "Volcanic (minds) Admin — manifest-driven backoffice engine on Refine + shadcn/ui",
  "type": "module",
  "keywords": [
    "volcanic",
    "volcanic admin",
    "open source",
    "admin",
    "backoffice",
    "admin panel",
    "manifest-driven",
    "refine",
    "shadcn",
    "react",
    "typescript"
  ],
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/style.css",
    "./tailwind-preset": "./tailwind-preset.js"
  },
  "files": [
    "dist",
    "tailwind-preset.js",
    "README.md",
    "scripts",
    "manifest.v2.schema.json"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build --config vite.config.lib.ts",
    "build:demo": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "pull:manifest": "node scripts/pull-manifest.mjs"
  },
  "peerDependencies": {
    "@refinedev/core": "^4.57.0",
    "@refinedev/react-hook-form": "^4.10.0",
    "@refinedev/react-router": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router": "^7.1.1"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@refinedev/core": "^4.57.0",
    "@refinedev/react-hook-form": "^4.10.0",
    "@refinedev/react-router": "^1.0.1",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router": "^7.1.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volcanicminds/volcanic-admin.git"
  },
  "homepage": "https://volcanicminds.com",
  "author": "Volcanic Minds <developers@volcanicminds.com> (https://volcanicminds.com)",
  "bin": {
    "volcanic-admin-pull": "scripts/pull-manifest.mjs"
  }
}
